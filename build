#!/usr/bin/env bash
set -euo pipefail

npm install
npm run build
npm test

if [[ "${1:-}" == "deploy" ]]; then
  version=$(node -e "console.log(require('./package.json').version)")
  echo "Deploying v${version}..."

  git add -A
  git commit -m "Bump version to ${version}"
  git tag "v${version}"
  git push
  git push --tags

  read -rp "npm OTP: " otp
  npm publish --otp="${otp}"
fi
